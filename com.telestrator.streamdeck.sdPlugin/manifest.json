{
  "SDKVersion": 2,
  "Author": "Brendan Welsh",
  "Name": "OBS Telestrator",
  "Description": "Control the OBS Telestrator from your Stream Deck over obs-websocket.",
  "Category": "OBS Telestrator",
  "CategoryIcon": "icons/category",
  "Icon": "icons/plugin",
  "URL": "https://github.com/brendanwelsh/obs-telestrator-streamdeck",
  "Version": "1.0.0",
  "CodePath": "app.html",
  "PropertyInspectorPath": "pi.html",
  "OS": [
    { "Platform": "windows", "MinimumVersion": "10" }
  ],
  "Software": {
    "MinimumVersion": "5.0"
  },
  "Actions": [
    {
      "UUID": "com.telestrator.streamdeck.command",
      "Name": "Telestrator Command",
      "Tooltip": "Fire a telestrator command in OBS (pick which in the inspector).",
